#!/usr/bin/env bash
# SDL pre-commit hook (warn-only).
# If the staged diff touches code but no docs/sdl/*/ file is staged in the same
# commit, print a single-line warning. Never blocks the commit.

set -eu

repo_root="$(git rev-parse --show-toplevel 2>/dev/null || true)"
[[ -z "$repo_root" ]] && exit 0
[[ -d "$repo_root/docs/sdl" ]] || exit 0

staged="$(git diff --cached --name-only)"
[[ -z "$staged" ]] && exit 0

code_changed="false"
sdl_changed="false"

while IFS= read -r f; do
  case "$f" in
    docs/sdl/*) sdl_changed="true" ;;
    *.md|*.txt|*.yml|*.yaml|*.json|*.lock|.gitignore|LICENSE*|README*) ;;
    *) code_changed="true" ;;
  esac
done <<< "$staged"

if [[ "$code_changed" == "true" && "$sdl_changed" == "false" ]]; then
  printf '\033[1;33m[sdl]\033[0m code changed without an SDL update. Consider running sdl-review before pushing.\n' >&2
fi

exit 0
